%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#e1f5fe', 'primaryTextColor': '#01579b', 'primaryBorderColor': '#0288d1', 'lineColor': '#0288d1', 'secondaryColor': '#fff3e0', 'tertiaryColor': '#e8f5e9', 'fontFamily': 'Inter, system-ui, sans-serif'}}}%%
graph TB
    subgraph External["🌐 外部服务 — 阿里云百炼"]
        API_EMB["text-embedding-v3<br/>向量嵌入"]
        API_RERANK["gte-rerank<br/>精排模型"]
        API_LLM["qwen-max<br/>大模型审核"]
    end

    subgraph Data["📁 数据层"]
        DOCS["监管原文<br/>PDF / DOCX"]
        CHUNKS[("data/chunks/chunks.json<br/>条文分块")]
        CITATIONS[("data/chunks/citations.json<br/>引用关系")]
    end

    subgraph Indexing["🔍 索引层"]
        DENSE["DenseIndex<br/>FAISS + 1024维向量<br/>IndexFlatIP"]
        SPARSE["SparseIndex<br/>BM25Okapi + jieba分词<br/>自定义监管词表"]
        IDX_FAISS[("data/indexes/faiss.index")]
        IDX_BM25[("data/indexes/bm25.pkl")]
    end

    subgraph Retrieval["⚡ 检索层"]
        QRW["QueryRewriter<br/>规则匹配违规类型 V01-V11<br/>否定检测 + Fallback关键词"]
        HS["HybridSearch<br/>多查询改写 → BM25+Dense → RRF融合<br/>Top10 → 引用图扩展 → gte-rerank精排"]
        CG["CitationGraph<br/>同文档条文引用扩展<br/>RRF>0.5 触发"]
    end

    subgraph Confidence["📊 置信度层"]
        CONF["ConfidenceCalculator<br/>四因子加权评分"]
        C1["rerank_score (W=0.4)<br/>mean/max 加权"]
        C2["chunk_coverage (W=0.2)<br/>阈值通过率"]
        C3["multi_query_agreement (W=0.2)<br/>Jaccard 相似度"]
        C4["semantic_diversity (W=0.2)<br/>余弦距离倒数"]
        LOW["low-evidence cap<br/>全低分合规 → 上限0.4"]
    end

    subgraph LLMReview["🤖 LLM 审核层"]
        PB["PromptBuilder<br/>system: 角色+违规表+输出schema<br/>user: 文案+条文+参考"]
        REV["LLMReviewer<br/>Bailian API / Mock Fallback<br/>指数退避重试"]
        OP["OutputParser<br/>JSON解析 + Schema校验"]
    end

    subgraph Pipeline["🔄 Pipeline 编排层"]
        PL["CompliancePipeline.review()<br/>端到端编排 + 异常兜底"]
    end

    subgraph Output["📤 输出"]
        RES["{ compliant, violations[],<br/>confidence, confidence_breakdown,<br/>action_advice, top_chunks[],<br/>reference_chunks[], warning? }"]
    end

    DOCS --> CHUNKS
    DOCS --> CITATIONS
    CHUNKS --> DENSE
    CHUNKS --> SPARSE
    DENSE --> IDX_FAISS
    SPARSE --> IDX_BM25
    DENSE -.-> API_EMB
    SPARSE -.-> API_EMB

    CHUNKS --> CG
    CITATIONS --> CG

    PL --> QRW
    QRW --> HS
    HS --> DENSE
    HS --> SPARSE
    HS --> CG
    HS -.-> API_RERANK

    PL --> CONF
    CONF --> C1
    CONF --> C2
    CONF --> C3
    CONF --> C4
    CONF --> LOW

    PL --> PB
    PB --> REV
    REV -.-> API_LLM
    REV --> OP

    PL --> RES
